// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User profile table - stores app-specific user data
// The actual authentication (passwords, emails) is managed by Supabase Auth
model User {
  id              String    @id @default(cuid())
  supabaseUserId  String    @unique // Foreign key reference to Supabase Auth user
  username        String    @unique
  email           String    @unique
  displayName     String?
  avatarUrl       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([supabaseUserId])
}
